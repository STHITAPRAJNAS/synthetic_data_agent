# ============================================================
# Synthetic Data Agent — Environment Configuration Template
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ── Databricks ──────────────────────────────────────────────
DATABRICKS_HOST=https://<workspace>.azuredatabricks.net
DATABRICKS_TOKEN=dapi_<your_personal_access_token>
DATABRICKS_SCHEMA=synthetic_data

# ── Output catalog (where generated tables are written) ─────
OUTPUT_CATALOG=dev

# ── Database (PostgreSQL — pgvector required) ───────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/synthetic_data

# ── Google Generative AI ────────────────────────────────────
# Required for LLM-based PII detection heuristic (layer 3).
# Set to a Gemini API key or leave blank to skip LLM detection.
GOOGLE_API_KEY=

# ── Agent model selection ───────────────────────────────────
# Overrides the default model used by all agents.
# AGENT_MODEL=gemini-2.5-flash

# ── Profiling ───────────────────────────────────────────────
MAX_PROFILING_SAMPLE_ROWS=50000

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
